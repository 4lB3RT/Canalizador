APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=canalizador
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Video Generator Provider: 'luma' or 'sora'
VIDEO_GENERATOR_PROVIDER=luma

# Luma AI - https://lumalabs.ai
LUMA_API_KEY=

# OpenAI (for Sora 2 and other OpenAI services)
OPENAI_API_KEY=

# Sora-2 Video Generation Configuration
# Model: 'sora-2' (standard, lower cost) or 'sora-2-pro' (pro, higher cost)
# RECOMMENDED FOR TESTING: 'sora-2' (minimum cost)
SORA_MODEL=sora-2

# Duration in seconds (lower = lower cost)
# Default: 9 seconds (aligned with script generation)
# For testing with minimum cost: Consider 5-7 seconds
SORA_DURATION=9

# Resolution: '1280x720' (720p), '854x480' (480p), '640x360' (360p)
# Lower resolution = lower cost
# DEFAULT FOR TESTING: 360p (minimum cost)
# For production: Use 480p or 720p
SORA_RESOLUTION=640x360

VITE_APP_NAME="${APP_NAME}"
